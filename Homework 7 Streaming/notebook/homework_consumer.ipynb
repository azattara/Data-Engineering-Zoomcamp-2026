import os
import sys
from kafka import KafkaConsumer
from dataclasses import dataclass
import json
@dataclass
class GreenRide:
    lpep_pickup_datetime: str
    lpep_dropoff_datetime: str
    PULocationID: int
    DOLocationID: int
    passenger_count: int
    trip_distance: float
    tip_amount: float
    total_amount: float
count = 0
def green_ride_deserializer(data: bytes) -> GreenRide:
    return GreenRide(**json.loads(data.decode('utf-8')))

from kafka import KafkaConsumer

server = 'localhost:9092'
topic_name = 'green-trips'


def main():
    global count
     
    consumer = KafkaConsumer(
        topic_name,
        bootstrap_servers=[server],
        auto_offset_reset='earliest',
        group_id='green-rides-counter-notebook', 
        value_deserializer=green_ride_deserializer,
        consumer_timeout_ms=5000 
    )

    print("Starting consume...")
    try:
        for message in consumer:
            ride = message.value
            if ride.trip_distance > 5:
                count += 1
    except Exception as e:
        print(f"Erro: {e}")
    finally:
        consumer.close()


if __name__ == '__main__':
    main()
    print(f'The are {count} trips with trip_distance greater than 5.0 kilometers')
